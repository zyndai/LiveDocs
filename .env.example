# ============================================================
# Copy to .env for local dev (keys not needed — enter them
# in the dashboard at http://localhost:8002/dashboard/settings)
# ============================================================

# Override Qdrant if not on localhost
# QDRANT_URL=https://xyz.us-east4-0.gcp.cloud.qdrant.io
# QDRANT_API_KEY=your-qdrant-cloud-api-key

# API keys can also be set here instead of the dashboard
# GOOGLE_API_KEY=AIza...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: private GitHub docs repo (for scripts/fetch_docs.py)
# GITHUB_TOKEN=ghp_...
