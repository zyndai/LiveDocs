# ============================================================
# Copy this file to .env and fill in your keys.
#   cp .env.example .env
# ============================================================


# ── REQUIRED ────────────────────────────────────────────────
# One key for everything: embeddings (text-embedding-004) + LLM (gemini-2.5-flash)

GOOGLE_API_KEY=
# Get key (free): https://aistudio.google.com/apikey


# ── OPTIONAL: switch LLM provider ───────────────────────────
# Change LLM_PROVIDER in config.py, then set the matching key.
# Embeddings always use Gemini (GOOGLE_API_KEY stays required).

# OpenAI LLM  →  LLM_PROVIDER = "openai"
# OPENAI_API_KEY=sk-...

# Anthropic LLM  →  LLM_PROVIDER = "anthropic"
# ANTHROPIC_API_KEY=sk-ant-...


# ── OPTIONAL: private GitHub docs repo ──────────────────────
# Only needed if using fetch_docs.py to pull from a private repo.
# GITHUB_TOKEN=ghp_...
